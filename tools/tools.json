      "endpoint": "/api/theme/theme/{name}",
      "parameters": {
        "name": "string"
      }
    },
    {
      "name": "set_theme",
      "description": "Apply one theme through the deterministic theme service",
      "method": "POST",
      "endpoint": "/api/theme/theme/{theme}/apply",
      "parameters": {

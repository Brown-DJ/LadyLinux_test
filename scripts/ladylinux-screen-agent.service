# scripts/ladylinux-screen-agent.service
# Install to: ~/.config/systemd/user/ladylinux-screen-agent.service
# Enable with: systemctl --user enable --now ladylinux-screen-agent
#
# Runs as the desktop user so it has access to $DISPLAY/$WAYLAND_DISPLAY.
# Writes screen state to /var/lib/ladylinux/data/screen_state.json
# which the ladylinux API service reads on every prompt.

[Unit]
Description=LadyLinux Screen State Agent
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
# Run from the venv so psutil is available
ExecStart=/opt/ladylinux/venv/bin/python /opt/ladylinux/app/core/screen/screen_agent.py
Restart=on-failure
RestartSec=5

# Inherit the desktop session environment so DISPLAY/WAYLAND_DISPLAY are set
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=graphical-session.target
